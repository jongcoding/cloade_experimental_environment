        <!-- 1: webapp routes by group -->
        <mxCell id="e_webapp_emp" value="&lt;b&gt;default → employee_agent&lt;br&gt;audience filter [public, employee]&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#147EBA;strokeWidth=3;fontSize=22;fontColor=#147EBA;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="webapp" target="emp_agent"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_webapp_adm" value="&lt;b&gt;cognito:groups contains admin&lt;br&gt;→ admin_agent&lt;br&gt;audience filter [public, employee, admin]&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#01A88D;strokeWidth=3;fontSize=22;fontColor=#01A88D;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="webapp" target="adm_agent"><mxGeometry relative="1" as="geometry" /></mxCell>

