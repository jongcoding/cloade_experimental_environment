        <mxCell id="e_adm_kb" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#01A88D;strokeWidth=2;" edge="1" parent="1" source="adm_agent" target="kb"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 3: ADD_COMMENT mass assignment -->
        <mxCell id="e_inv_comments" value="&lt;b&gt;Stage 2  ADD_COMMENT(audience=admin)&lt;br&gt;writes body.md + body.md.metadata.json&lt;br&gt;mass assignment — no validation&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#d79b00;strokeWidth=4;dashed=1;dashPattern=8 4;fontSize=22;fontColor=#d79b00;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="inventory_lambda" target="prefix_comments"><mxGeometry relative="1" as="geometry" /></mxCell>

