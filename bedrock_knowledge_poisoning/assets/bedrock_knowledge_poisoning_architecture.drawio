        <mxCell id="e_adm_admops" value="&lt;b&gt;admin only&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=3;fontSize=22;fontColor=#b85450;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="adm_agent" target="adminops_lambda"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- both agents to KB -->
