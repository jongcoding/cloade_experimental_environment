        <mxCell id="e_cog_auto" value="&lt;b&gt;Stage 0 auto-confirm&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=2;fontSize=22;fontColor=#b85450;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cognito" target="autoconfirm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cog_api" value="&lt;b&gt;JWT (cognito:groups)&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#545B64;strokeWidth=2;fontSize=22;fontColor=#545B64;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cognito" target="apigw"><mxGeometry relative="1" as="geometry" /></mxCell>
